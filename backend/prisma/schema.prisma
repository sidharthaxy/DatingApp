datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Status {
  UNDER_REVIEW
  APPROVED
  REJECTED
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
}

enum RelationshipGoal {
  LONG_TERM
  LONG_TERM_OPEN_TO_SHORT
  SHORT_TERM_OPEN_TO_LONG
  FUN_NEW_FRIENDS
  STILL_FIGURING_OUT
}

enum InterestedIn {
  MEN
  WOMEN
  EVERYONE
}

enum SwipeType {
  LIKE
  DISLIKE
}

enum AdminActionType {
  APPROVE
  REJECT
  WARN
  BAN
}

enum ReportReason {
  INAPPROPRIATE_CONTENT
  SPAM
  HARASSMENT
  SCAM
  OTHER
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

enum AppealStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SubscriptionTier {
  FREE
  PREMIUM
  ELITE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum BillingCycle {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum PaymentStatus {
  CREATED
  PAID
  FAILED
  REFUNDED
}

model User {
  id                String    @id @default(uuid())
  firebase_uid      String?   @unique
  email             String?   @unique
  phone             String?   @unique
  first_name        String?
  dob               DateTime?
  gender            Gender?
  bio               String?   @db.Text
  city              String?
  latitude          Float?
  longitude         Float?
  height_cm         Int?
  job_title         String?
  company           String?
  living_in         String?
  relationship_goal RelationshipGoal?
  interested_in     InterestedIn?
  discover_enabled    Boolean   @default(true)
  is_profile_complete Boolean   @default(false)
  last_login_at       DateTime?
  status              Status    @default(UNDER_REVIEW)
  kyc_video_url     String?
  fcm_token         String?
  boost_expires_at  DateTime?
  profile_views     Int       @default(0)
  report_count      Int       @default(0)

  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt

  photos            Photo[]
  user_interests    UserInterest[]
  swipes_from       Swipe[]   @relation("SwipesFrom")
  swipes_to         Swipe[]   @relation("SwipesTo")
  messages_from     Message[] @relation("MessagesFrom")
  messages_to       Message[] @relation("MessagesTo")
  admin_actions     AdminAction[]
  matches_1         Match[]   @relation("Matches1")
  matches_2         Match[]   @relation("Matches2")

  favorites_given   Favorite[] @relation("FavoritesUser")
  favorites_received Favorite[] @relation("FavoritesTarget")
  wishlists         Wishlist[]
  wishlisted_in     WishlistMember[] @relation("WishlistedUsers")
  reports_given     Report[]  @relation("ReportsGiven")
  reports_received  Report[]  @relation("ReportsReceived")
  appeals           Appeal[]
  subscriptions     Subscription[]
  payments          Payment[]

  @@index([created_at])
  @@index([last_login_at])
  @@index([status])
  @@index([discover_enabled])

  subscription_tier SubscriptionTier @default(FREE)
}

model Photo {
  id         String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  url        String
  version    Int      @default(1)
  status     Status   @default(UNDER_REVIEW)
  created_at DateTime @default(now())
}

model Interest {
  id             String         @id @default(uuid())
  name           String
  category       String
  user_interests UserInterest[]
}

model UserInterest {
  user_id     String
  interest_id String
  user        User     @relation(fields: [user_id], references: [id])
  interest    Interest @relation(fields: [interest_id], references: [id])

  @@id([user_id, interest_id])
}

model Swipe {
  id         String    @id @default(uuid())
  from_user  String
  to_user    String
  type       SwipeType
  created_at DateTime  @default(now())

  fromUser User @relation("SwipesFrom", fields: [from_user], references: [id])
  toUser   User @relation("SwipesTo", fields: [to_user], references: [id])

  @@unique([from_user, to_user]) // Prevent duplicate swipes
  @@index([from_user, to_user])
}

model Message {
  id         String   @id @default(uuid())
  from_user  String
  to_user    String
  content    String?  @db.Text
  media_url  String?
  is_read    Boolean  @default(false)
  is_edited  Boolean  @default(false)
  is_deleted Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  fromUser User @relation("MessagesFrom", fields: [from_user], references: [id])
  toUser   User @relation("MessagesTo", fields: [to_user], references: [id])

  @@index([from_user, to_user, created_at])
}

model AdminAction {
  id         String          @id @default(uuid())
  user_id    String
  action     AdminActionType
  reason     String?
  remark     String?         @db.Text
  created_at DateTime        @default(now())

  user       User @relation(fields: [user_id], references: [id])
}

model Match {
  id         String   @id @default(uuid())
  user1_id   String
  user2_id   String
  created_at DateTime @default(now())

  user1 User @relation("Matches1", fields: [user1_id], references: [id])
  user2 User @relation("Matches2", fields: [user2_id], references: [id])

  @@unique([user1_id, user2_id])
  @@index([user1_id, user2_id])
}

model Favorite {
  id         String   @id @default(uuid())
  user_id    String
  target_id  String
  created_at DateTime @default(now())

  user   User @relation("FavoritesUser", fields: [user_id], references: [id])
  target User @relation("FavoritesTarget", fields: [target_id], references: [id])

  @@unique([user_id, target_id])
}

model Wishlist {
  id         String   @id @default(uuid())
  user_id    String
  name       String
  is_public  Boolean  @default(false)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user       User             @relation(fields: [user_id], references: [id])
  members    WishlistMember[]
}

model WishlistMember {
  wishlist_id String
  target_id   String
  created_at  DateTime @default(now())

  wishlist Wishlist @relation(fields: [wishlist_id], references: [id], onDelete: Cascade)
  target   User     @relation("WishlistedUsers", fields: [target_id], references: [id])

  @@id([wishlist_id, target_id])
}

model Report {
  id          String       @id @default(uuid())
  reporter_id String
  reported_id String
  reason      ReportReason
  evidence    String?      @db.Text
  status      ReportStatus @default(PENDING)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt

  reporter User @relation("ReportsGiven", fields: [reporter_id], references: [id])
  reported User @relation("ReportsReceived", fields: [reported_id], references: [id])

  @@index([reporter_id, reported_id])
}

model Appeal {
  id         String       @id @default(uuid())
  user_id    String
  reason     String       @db.Text
  status     AppealStatus @default(PENDING)
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt

  user User @relation(fields: [user_id], references: [id])
}

model Subscription {
  id                      String             @id @default(uuid())
  user_id                 String
  tier                    SubscriptionTier
  billing_cycle           BillingCycle
  status                  SubscriptionStatus @default(ACTIVE)
  razorpay_subscription_id String?           @unique
  starts_at               DateTime           @default(now())
  expires_at              DateTime
  created_at              DateTime           @default(now())
  updated_at              DateTime           @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id, status])
}

model Payment {
  id                  String        @id @default(uuid())
  user_id             String
  subscription_id     String?
  razorpay_order_id   String?       @unique
  razorpay_payment_id String?       @unique
  razorpay_signature  String?
  amount              Int           // in paise (INR smallest unit)
  currency            String        @default("INR")
  status              PaymentStatus @default(CREATED)
  tier                SubscriptionTier
  billing_cycle       BillingCycle
  created_at          DateTime      @default(now())
  updated_at          DateTime      @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@index([user_id])
}
